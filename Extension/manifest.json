{
  "manifest_version": 3,
  "name": "Pinit",
  "version": "2.1",
  "description": "Intelligently pin and return to AI chat messages, even in virtualized lists.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://grok.com/*",
    "https://x.com/i/grok/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "pin.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://grok.com/*",
        "https://x.com/i/grok/*"
      ],
      "js": [
        "modules/message-detector.js",
        "modules/fingerprint.js",
        "modules/matching-engine.js",
        "modules/mutation-tracker.js",
        "modules/restore-engine.js",
        "modules/ui-injector.js",
        "content.js"
      ],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "pin.png",
    "48": "pin.png",
    "128": "pin.png"
  }
}