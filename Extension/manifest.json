{
  "manifest_version": 3,
  "name": "Pinit",
  "version": "2.4",
  "description": "Intelligently pin and return to AI chat messages, even in virtualized lists.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "pinit-icon-clear.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "modules/message-detector.js",
        "modules/fingerprint.js",
        "modules/matching-engine.js",
        "modules/mutation-tracker.js",
        "modules/restore-engine.js",
        "modules/ui-injector.js",
        "content.js"
      ],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "pinit-icon-clear.png",
    "48": "pinit-icon-clear.png",
    "128": "pinit-icon-clear.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["pinit-icon-clear.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "capture-page": {
      "suggested_key": {
        "default": "Alt+Shift+P",
        "mac": "Alt+Shift+P"
      },
      "description": "Pin the current page view"
    }
  }
}